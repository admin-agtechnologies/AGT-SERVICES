# ============================================================
#  AGT Media Service — Variables d'environnement
#  Copier ce fichier en .env et remplir les valeurs
# ============================================================

# Service
NODE_ENV=development
PORT=7003
SERVICE_NAME=agt-media

# Base de données PostgreSQL
DATABASE_URL=postgresql://media_user:media_pass@agt-media-db:5432/media_db

# Redis (cache + BullMQ queue)
REDIS_URL=redis://agt-redis:6379

# Auth Service — validation JWT et S2S
AUTH_SERVICE_URL=http://agt-auth-service:7000/api/v1

# Tokens S2S (obtenu depuis Auth après création de la plateforme S2S)
S2S_AUTH_URL=http://agt-auth-service:7000/api/v1
S2S_CLIENT_ID=
S2S_CLIENT_SECRET=

# Stockage (local pour MVP, s3/gcs pour production)
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=/app/uploads

# Sécurité des URLs signées (HMAC)
SIGNED_URL_SECRET=change-me-signed-url-secret-key-32chars

# Rate limiting
RATE_LIMIT_USER=30
RATE_LIMIT_S2S=100

# Limites d'upload par défaut (50 MB)
MAX_FILE_SIZE_BYTES=52428800

# Traitement Sharp
THUMBNAIL_SIZES=150x150,300x300
COMPRESSION_QUALITY=80

# BullMQ — queue de traitement
QUEUE_NAME=media-processing

# Logs
LOG_LEVEL=info
