# ============================================================
# AGT Chat Service v1.2 — Variables d'environnement
# ============================================================
# Copier ce fichier en .env et adapter les valeurs
# Le fichier .env ne doit JAMAIS être commité (voir .gitignore)
# ============================================================

# --- Serveur ---
PORT=7008
NODE_ENV=production

# --- Base de données PostgreSQL ---
# Format : postgresql://<user>:<password>@<host>:<port>/<dbname>
# En Docker : l'hôte est le container_name du service db
DATABASE_URL=postgresql://agt_user:agt_password@agt-chat-db:5432/agt-chat-db

# --- Redis ---
# Utilisé pour : présence, typing, rate limiting, cache auth/users, token S2S
# En Docker : l'hôte est le container_name du service redis
REDIS_URL=redis://agt-chat-redis:6379/0

# --- RabbitMQ (broker partagé AGT) ---
# ⚠️ Credentials du broker PARTAGÉ — différents du défaut guest/guest
# Ne pas modifier sauf si votre instance RabbitMQ a des credentials différents
BROKER_URL=amqp://agt_rabbit:agt_rabbit_password@agt-rabbitmq:5672

# --- Service Auth v2.1 ---
# URL interne Docker (ne pas utiliser localhost — utiliser le container_name)
AUTH_SERVICE_URL=http://agt-auth-service:7000

# --- Service Users v1.0 ---
USERS_SERVICE_URL=http://agt-users-service:7001

# --- Service Notification v1.2 ---
NOTIFICATION_SERVICE_URL=http://agt-notif-service:7002

# --- Authentification S2S (Service-to-Service) ---
# S2S_SECRET : secret partagé legacy (conservé pour compatibilité)
S2S_SECRET=change-me-s2s-secret

# S2S_CLIENT_ID et S2S_CLIENT_SECRET :
# Credentials de la plateforme Chat enregistrée dans Auth Service.
# Obtenir via : POST /api/v1/auth/platforms dans Swagger Auth
# ⚠️ Le client_secret n'est affiché qu'une seule fois à la création — le noter immédiatement
# ⚠️ Ne jamais commiter ces valeurs — elles restent dans .env uniquement
S2S_CLIENT_ID=<uuid-de-la-plateforme-chat-dans-auth>
S2S_CLIENT_SECRET=<client-secret-de-la-plateforme-chat>

# --- WebSocket CORS ---
# Origines autorisées pour les connexions WebSocket
# Pour plusieurs origines, séparer par des virgules (CSV)
# Exemple : http://localhost:3000,http://localhost:3001,https://app.agtechnologies.com
SOCKET_IO_CORS_ORIGIN=http://localhost:3000

# --- Comportement métier ---
# Durée de l'indicateur "en train d'écrire" (millisecondes)
TYPING_TIMEOUT_MS=3000

# Délai maximum pour éditer un message après envoi (minutes)
MESSAGE_EDIT_DELAY_MIN=15

# Timeout avant remise en attente d'un transfert non pris en charge (minutes)
TRANSFER_TIMEOUT_MIN=10

# --- Cache TTL ---
# TTL du cache Redis pour les profils utilisateurs (secondes)
USERS_CACHE_TTL_SEC=300

# TTL du cache Redis pour les tokens Auth validés (secondes)
AUTH_CACHE_TTL_SEC=30

# --- Rate Limiting ---
# Nombre maximum de messages qu'un utilisateur peut envoyer par minute
RATE_LIMIT_USER_MSG_PER_MIN=30

# Nombre maximum de messages par conversation par minute
RATE_LIMIT_CONV_MSG_PER_MIN=100

# --- Base de données (avancé) ---
# Taille maximale du pool de connexions PostgreSQL
DB_POOL_MAX=10```