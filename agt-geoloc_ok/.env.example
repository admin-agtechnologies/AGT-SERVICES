# ── AGT Geolocation Service v1.2 — Variables d'environnement ──────────────────
# Copier ce fichier en .env et adapter les valeurs à votre environnement.
# Ne jamais committer le fichier .env.

# ── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=7009

# ── PostgreSQL + PostGIS ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5439
DB_NAME=agt_geoloc_db
DB_USER=geoloc_user
DB_PASSWORD=geoloc_password

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6385
REDIS_PASSWORD=
# TTL par défaut (secondes) pour les entités live en Redis
REDIS_DEFAULT_TTL=30

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://agt_rabbit:agt_rabbit_password@localhost:5675
RABBITMQ_EXCHANGE=agt.geoloc

# ── Auth Service ─────────────────────────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:7000
# Chemin vers la clé publique RSA du service Auth (pour valider les JWT)
AUTH_PUBLIC_KEY_PATH=./keys/auth_public.pem
# Token S2S de ce service (créer une plateforme dans Auth pour obtenir ces valeurs)
S2S_CLIENT_ID=
S2S_CLIENT_SECRET=
JWT_AUDIENCE=

# ── Providers ETA / Géocodage ─────────────────────────────────────────────────
# Google Maps (payant) — laisser vide pour n'utiliser que OSRM/Nominatim
GOOGLE_MAPS_API_KEY=

# OSRM (self-hosted ou instance publique démo — ne pas utiliser en prod)
OSRM_URL=http://router.project-osrm.org

# Nominatim (gratuit OpenStreetMap — respecter max 1 req/s en prod)
NOMINATIM_URL=https://nominatim.openstreetmap.org

# ── Batch writer PostGIS ──────────────────────────────────────────────────────
# Intervalle de flush en secondes (10–30 recommandé)
BATCH_FLUSH_SECONDS=15

# ── Geofencing ────────────────────────────────────────────────────────────────
# Intervalle de synchro du cache geofence en ms
GEOFENCE_CACHE_SYNC_MS=10000
