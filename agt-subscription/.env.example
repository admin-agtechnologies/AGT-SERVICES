# ============================================================
# AGT Subscription Service v1.0 - Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs.
# ============================================================

# --- Django ---
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# --- Base de données ---
DATABASE_URL=postgresql://sub_user:sub_password@db:5432/agt_subscription_db

# --- Cache Redis ---
REDIS_URL=redis://redis:6379/4

# --- Auth Service (clé publique JWT RS256) ---
AUTH_SERVICE_PUBLIC_KEY_PATH=/app/keys/auth_public.pem

# --- Services externes ---
PAYMENT_SERVICE_URL=http://agt-payment-service:7005/api/v1
NOTIFICATION_SERVICE_URL=http://agt-notification-service:7002/api/v1

# --- S2S — Credentials inter-services (créer via POST /auth/platforms) ---
S2S_AUTH_URL=http://agt-auth-service:7000/api/v1
S2S_CLIENT_ID=<uuid-obtenu-depuis-auth>
S2S_CLIENT_SECRET=<secret-obtenu-depuis-auth>

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
