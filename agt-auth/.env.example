# ============================================================
# AGT Auth Service v1.0 — Variables d'environnement
# ============================================================

# ─── Django ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,agt-auth-service

# ─── Base de données ──────────────────────────────────────────────────────────
# Correction : l'hôte est le container_name 'agt-auth-db'
DATABASE_URL=postgresql://agt_user:agt_password@agt-auth-db:5432/agt-auth-db

# ─── Redis ────────────────────────────────────────────────────────────────────
# Correction : l'hôte est le container_name 'agt-auth-redis'
REDIS_URL=redis://agt-auth-redis:6379/0

# ─── JWT (RS256) ──────────────────────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=/app/keys/private.pem
JWT_PUBLIC_KEY_PATH=/app/keys/public.pem
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
JWT_ISSUER=agt-auth
JWT_AUDIENCE=agt-ecosystem

# ─── Bcrypt ───────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_API_KEY=change-me-admin-api-key-very-secret

# ─── Services inter-microservices ─────────────────────────────────────────────
# Correction : Utilisation des container_names globaux
NOTIFICATION_SERVICE_URL=http://agt-notif-service:7002/api/v1
USERS_SERVICE_URL=http://agt-users-service:7001/api/v1

# ─── OAuth Google ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:7000/api/v1/auth/oauth/google/callback

# ─── OAuth Facebook ───────────────────────────────────────────────────────────
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_REDIRECT_URI=http://localhost:7000/api/v1/auth/oauth/facebook/callback

# ─── OTP / Magic Link ─────────────────────────────────────────────────────────
OTP_TTL=300
MAGIC_LINK_TTL=600

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_LOGIN=10
BRUTE_FORCE_MAX=5
BRUTE_FORCE_LOCKOUT=900

# ─── Tokens ───────────────────────────────────────────────────────────────────
MAX_REFRESH_TOKENS=5

# ─── Cookies ──────────────────────────────────────────────────────────────────
COOKIE_SECURE=False
COOKIE_SAMESITE=Lax

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001